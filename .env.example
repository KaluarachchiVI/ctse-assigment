# Copy this file to ".env" in the repo root (same folder as docker-compose.yml).
# Docker Compose loads .env automatically for variable substitution.
# Never commit ".env" — it contains secrets.

# Stripe Checkout (payment-service). Use sk_test_... for development.
PAYMENT_GATEWAY_PROVIDER=stripe-checkout
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_CURRENCY=usd

# When true, payment-service validates users against user-service before checkout.
USER_SERVICE_ENABLED=true
